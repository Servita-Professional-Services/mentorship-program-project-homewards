generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id          String   @id @default(uuid())
  nhsNumber   String   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime

  wardId String?
  ward   Ward?   @relation(fields: [wardId], references: [id])

  appointments     Appointment[]
  observations     Observation[]
  escalations      Escalation[]
  dischargeRecords DischargeRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ward {
  id         String  @id @default(uuid())
  name       String
  location   String?
  capacity   Int?
  speciality String?

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  dateTime DateTime
  status   String // e.g. Scheduled, Completed, Cancelled

  createdAt DateTime @default(now())
}

model Observation {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  type       String // e.g. BP, HR
  value      String
  recordedAt DateTime

  createdAt DateTime @default(now())
}

model Escalation {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  level  String // e.g. LOW | MEDIUM | HIGH
  reason String?
  status String  @default("OPEN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DischargeRecord {
  id        String @id @default(uuid())
  patientId String

  dateOfBloodwork          DateTime
  supportPlanNeeded        Boolean
  dischargeReason          String
  preferredDateOfDischarge DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient           Patient            @relation(fields: [patientId], references: [id])
  medicationRecords MedicationRecord[]
}

model MedicationRecord {
  id             String @id @default(uuid())
  medicationName String
  amount         Float
  measurement    String

  dischargeRecordId String
  dischargeRecord   DischargeRecord @relation(fields: [dischargeRecordId], references: [id])
}
