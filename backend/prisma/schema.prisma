generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id          String   @id @default(uuid())
  nhsNumber   String   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime

  wardId String?
  ward   Ward?   @relation(fields: [wardId], references: [id])

  appointments Appointment[]
  observations Observation[]
  escalations  Escalation[]
  discharge    DischargeStatus?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  dischargeNotes DischargeNote[]
}

model Ward {
  id         String  @id @default(uuid())
  name       String
  location   String?
  capacity   Int?
  speciality String?

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  dateTime DateTime
  status   String // e.g. Scheduled, Completed, Cancelled

  createdAt DateTime @default(now())
}

model Observation {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  type       String // e.g. BP, HR
  value      String
  recordedAt DateTime

  createdAt DateTime @default(now())
}

model Escalation {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  level  String // e.g. LOW | MEDIUM | HIGH
  reason String?
  status String  @default("OPEN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DischargeStatus {
  id        String  @id @default(uuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id])

  status            String  @default("PLANNED") // e.g. PLANNED | DISCHARGED | CANCELLED
  notes             String?
  transportRequired Boolean @default(false)

  readySince  DateTime? // useful for escalation logic
  lastUpdated DateTime  @updatedAt

  createdAt DateTime @default(now())
}

model DischargeNote {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  createdBy String // azure ad user id of the staff member who created the note

  note      String
  createdAt DateTime @default(now())
}
