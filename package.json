{
  "name": "project-health-wards",
  "private": true,
  "version": "0.0.1",
  "description": "Project Virtual Wards — engineering mentorship monorepo skeleton",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "start": "pnpm dev",
    "dev": "pnpm --parallel --filter '@health-wards/frontend' --filter '@health-wards/api' dev",
    "build": "pnpm --filter '@health-wards/shared' build && pnpm --parallel --filter '@health-wards/frontend' --filter '@health-wards/api' build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --parallel --filter '@health-wards/frontend' --filter '@health-wards/api' test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "@storybook/test": "8.6.17"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "husky": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
